# Runtime
PET_REPORT_ENV=local
PET_REPORT_LOG_LEVEL=INFO
PET_REPORT_DATA_DIR=./runtime_data
PET_REPORT_REFERENCE_PATH=./data/reference_ranges/reference_ranges.yml
PET_REPORT_KNOWLEDGE_PATH=./data/knowledge_base/pet_report_knowledge.yml

# OCR backend: text | tesseract | paddleocr
# text: parse uploaded plain text or decoded file bytes, no heavy dependency
# tesseract: requires system tesseract + pytesseract
# paddleocr: requires paddleocr extra dependencies, best for Chinese lab reports
PET_REPORT_OCR_BACKEND=text
PET_REPORT_PADDLEOCR_LANG=ch
PET_REPORT_OCR_MIN_CONFIDENCE=0.45

# LLM backend: rule | transformers
# rule: deterministic local interpretation, runs everywhere
# transformers: local open-source Hugging Face model, no OpenAI call
PET_REPORT_LLM_PROVIDER=rule
PET_REPORT_HF_MODEL=Qwen/Qwen2.5-0.5B-Instruct
PET_REPORT_HF_DEVICE=cpu
PET_REPORT_HF_MAX_NEW_TOKENS=512
PET_REPORT_HF_TEMPERATURE=0.2
PET_REPORT_HF_DO_SAMPLE=false

# Safety and interpretation
PET_REPORT_ENABLE_RISK_GATE=true
PET_REPORT_ENABLE_RAG=true
PET_REPORT_REQUIRE_CITATIONS=true
PET_REPORT_MAX_REPORT_SIZE_MB=10

# API auth. Leave empty to disable. In production set a random secret.
PET_REPORT_API_KEY=
